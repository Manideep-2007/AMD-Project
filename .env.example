# Environment Configuration

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexusops"
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:5432/nexusops"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# JWT Authentication
JWT_SECRET="your-secret-key-min-32-chars-change-in-production-please"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# API Configuration
