# ───────────────────────────────────────────────────────
# NexusOps Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ───────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────
# PostgreSQL connection URL. Must be PostgreSQL 16+.
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/nexusops"

# ─── Redis ────────────────────────────────────────────
# Redis 7+ for queue, budget counters, velocity windows.
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ─── JWT Authentication ──────────────────────────────
# SECURITY: Must be minimum 64 random characters.
# Generate with: openssl rand -hex 64
JWT_SECRET="YOUR_JWT_SECRET_MIN_64_RANDOM_CHARS"
JWT_REFRESH_SECRET="YOUR_JWT_REFRESH_SECRET_MIN_64_RANDOM_CHARS"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# SECURITY: Must be minimum 32 random characters (used to sign cookies).
# Generate with: openssl rand -hex 32
COOKIE_SECRET="YOUR_COOKIE_SECRET_MIN_32_RANDOM_CHARS"

# ─── API Configuration ───────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"

# ─── Worker Configuration ────────────────────────────
WORKER_CONCURRENCY=10
# Port for the worker health check HTTP endpoint (used by Docker/K8s probes)
WORKER_HEALTH_PORT=3004

# ─── Proxy Configuration ─────────────────────────────
PROXY_PORT=3003
PROXY_URL="http://localhost:3003"
# Internal shared secret for proxy authentication.
# Generate with: openssl rand -hex 32
PROXY_INTERNAL_SECRET="YOUR_PROXY_INTERNAL_SECRET"

# ─── Policy Engine ───────────────────────────────────
POLICY_EVAL_TIMEOUT_MS=5

# ─── OpenTelemetry ───────────────────────────────────
# Jaeger endpoint for distributed tracing.
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_SERVICE_NAME="nexusops"

# ─── Supabase (optional, for MVP database) ──────────
# Obtain from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_SUPABASE_PROJECT_ID"
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ─── Frontend ────────────────────────────────────────
VITE_API_URL="http://localhost:3001"
VITE_WS_URL="ws://localhost:3001"

# ─── Tool Proxies (configure with your credentials) ─
GITHUB_TOKEN=""
JIRA_URL=""
JIRA_EMAIL=""
JIRA_API_TOKEN=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"

# ─── Encryption ──────────────────────────────────────
# AES-256-GCM key for encrypting customer DB URLs at rest.
# Generate with: openssl rand -hex 32
DB_URL_ENCRYPTION_KEY="YOUR_32_BYTE_HEX_KEY_HERE"

# ─── Email (for workspace invitations) ───────────────
EMAIL_PROVIDER="smtp"  # or "sendgrid"
SMTP_HOST="your_smtp_host"
SMTP_PORT="587"
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
SENDGRID_API_KEY="YOUR_SENDGRID_KEY"
FROM_EMAIL="no-reply@nexusops.io"
DASHBOARD_URL="http://localhost:3000"

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL="info"
PRETTY_LOGS="true"
